@{
	ViewBag.Title = "Confirmación de mail";
	
}

<!--begin::Root-->
<div class="d-flex flex-column flex-root" id="kt_app_root">
	<!--begin::Page bg image-->
	<style>
		body {
			background-image: url('../Template/assets/media/auth/bg8.jpg');
		}

		[data-bs-theme="dark"] body {
			background-image: url('../Template/assets/media/auth/bg8-dark.jpg');
		}</style>
	<!--end::Page bg image-->
	<!--begin::Authentication - Signup Welcome Message -->
	<div class="d-flex flex-column flex-center flex-column-fluid">
		<!--begin::Content-->
		<div class="d-flex flex-column flex-center text-center p-10">
			<!--begin::Wrapper-->
			<div class="card card-flush w-md-650px py-5">
				<div class="card-body py-15 py-lg-20">
					<!--begin::Logo-->
					<div class="mb-7">
						<a href="index.html" class="">
							<img alt="Logo" src="~/Template/assets/media/logos/custom-2.svg" class="h-40px" />
						</a>
					</div>
					<!--end::Logo-->
					@if (@ViewBag.verification)
					{
						<!--begin::Title-->
						<h1 class="fw-bolder text-gray-900 mb-5">@ViewBag.name, gracias por verificar tu cuenta.</h1>
						<!--end::Title-->
						<!--begin::Text-->
						<div class="fw-semibold fs-6 text-gray-500 mb-7">
							@ViewBag.message
							<br />
							Si no recibes tus datos de acceso en un lapso de 24 horas, escribe a: <a href='mailto:@ViewBag.emailSupport' class="link-primary fw-semibold"> @ViewBag.emailSupport </a>
							<br /> indica el correo electrónico que fue registrado y tu número de empleado.
						</div>
						<!--end::Text-->
						<!--begin::Illustration-->
						<div class="mb-0">
							<img src="~/Template/assets/media/auth/welcome.png" class="mw-100 mh-300px theme-light-show" alt="" />
							<img src="~/Template/assets/media/auth/welcome-dark.png" class="mw-100 mh-300px theme-dark-show" alt="" />
						</div>
						<!--end::Illustration-->
						<!--begin::Link-->
						<div class="mb-0">
							<a href="@Url.Action("SignIn","Account")" class="btn btn-sm btn-primary">Iniciar Sesión</a>
						</div>
						<!--end::Link-->
					}
					else
					{
						<!--begin::Title-->
						<h1 class="fw-bolder text-gray-900 mb-5">Verifica tu correo electrónico</h1>
						<!--end::Title-->
						<!--begin::Text-->
						<div class="fw-semibold fs-6 text-gray-500 mb-7">
							@ViewBag.message
						</div>
						<!--end::Text-->
						<!--begin::Illustration-->
						<div class="mb-0">
							<img src="~/Template/assets/media/auth/please-verify-your-email.png" class="mw-100 mh-300px theme-light-show" alt="" />
							<img src="~/Template/assets/media/auth/please-verify-your-email-dark.png" class="mw-100 mh-300px theme-dark-show" alt="" />
						</div>
						<!--end::Illustration-->
					}


					
				</div>
			</div>
			<!--end::Wrapper-->
		</div>
		<!--end::Content-->
	</div>
	<!--end::Authentication - Signup Welcome Message-->
</div>
<!--end::Root-->