	<!--begin::Javascript-->
	<script>var hostUrl = "assets/";</script>
	<!--begin::Global Javascript Bundle(mandatory for all pages)-->
	<script src="~/Template/assets/plugins/global/plugins.bundle.js"></script>
	<script src="~/Template/assets/js/scripts.bundle.js"></script>

	
	<script src="~/Template/custom/js/datatables/datatables.min.js"></script>

	<script src="~/Template/custom/js/Notifications.js"></script>
	<script src="~/Template/custom/js/Utilities.js"></script>
	<script src="~/Template/custom/js/Select2_es.js"></script>
	<script src="~/Template/custom/js/Flatpickr_es.js"></script>
	<script src="~/Template/custom/js/moment_es.min.js"></script>
	<!--end::Global Javascript Bundle-->
	


	<script>
		$(document).ready(function () {
			   $(function () {
				   //-- Configura los componentes Select2 en español
				   $.fn.select2.defaults.set('language', 'es');

				   moment.locale('es'); // Establecer el idioma a español

				   //-- Se reajusta el sidebar dependiendo de la cookie.
				   var CookieValue = document.cookie.replace(/(?:(?:^|.*;\s*)sidebar_minimize_state\s*\=\s*([^;]*).*$)|^.*$/, "$1");
				   if (CookieValue == "off")
					$('#kt_app_body').attr('data-kt-app-sidebar-minimize', 'on');                          
				   else
					$('#kt_app_body').removeAttr('data-kt-app-sidebar-minimize');			

			   });


				// Guarda en la cookie el estado del menú al hacer clic en el botón de toggle
				$('#kt_app_sidebar_toggle').on('click', function () {
					//Modifica la cookie del menu
					var CookieValue = document.cookie.replace(/(?:(?:^|.*;\s*)sidebar_minimize_state\s*\=\s*([^;]*).*$)|^.*$/, "$1");
					if (CookieValue == "off")
						document.cookie = "sidebar_minimize_state=on";
					else
						document.cookie = "sidebar_minimize_state=off";
				});

				Inputmask("decimal", {
					groupSeparator: ",",         // Separador de miles
					digits: 2,                   // Número de decimales
					digitsOptional: false,       // Obliga a mostrar los decimales
					prefix: "",                  // Prefijo de moneda
					rightAlignNumerics: false,   // Alineación del número (desactivado para mantenerlo a la izquierda)
					allowMinus: false,           // No permitir números negativos
					autoUnmask: true,            // Devuelve el valor sin formato al enviar
				}).mask("#Capital, #RiskWanted, #RiskReal, #PositionSize");
		});

		const clearButton = document.getElementById('btn_Calculadora_Limpiar');
		clearButton.addEventListener("click", function () {
			document.querySelector("#Capital").value = 0;
			document.querySelector("#RiskWanted").value = 0;
			document.querySelector("#RiskReal").value = 0;
			document.querySelector("#PositionSize").value = 0;
		});

		const calculateButton = document.getElementById('btn_Calculadora_Calcular');
		calculateButton.addEventListener("click", function () {
			calcularPosicion();

			
		});

		 function calcularPosicion() {
			let capital = parseFloat(document.getElementById("Capital").value);
			let riesgo = parseFloat(document.getElementById("RiskWanted").value);
			let riesgoReal = parseFloat(document.getElementById("RiskReal").value);

			if (isNaN(capital) || isNaN(riesgo) || isNaN(riesgoReal) || riesgoReal <= 0) {
				ShowNotification(3, "Ingrese valores válidos.");
				return;
			}

			let cantidadRiesgo = (capital * (riesgo / 100)); // Dinero a arriesgar
			let tamañoPosicion = cantidadRiesgo / riesgoReal; // Tamaño de la posición

			console.log(`Tamaño de la posición: ${tamañoPosicion.toFixed(2)} unidades`);

			document.querySelector("#PositionSize").value =  tamañoPosicion.toFixed(2);
		}
	</script>

	
	@Html.Partial("_Notifications")
    @await RenderSectionAsync("Scripts", required: false)
	<!--end::Javascript-->
