@model Web.Models.IndexViewModel

@{
	ViewBag.Title = "Cuenta";
}

<!--begin::Content wrapper-->
<div class="d-flex flex-column flex-column-fluid">
	<!--begin::Toolbar-->
	<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
		<!--begin::Toolbar container-->
		<div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
			<!--begin::Page title-->
			<div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
				<!--begin::Title-->
				<h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">Descripción general de la cuenta</h1>
				<!--end::Title-->
				<!--begin::Breadcrumb-->
				<ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">
						<a href="index.html" class="text-muted text-hover-primary">Inicio</a>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item">
						<span class="bullet bg-gray-500 w-5px h-2px"></span>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">Cuenta</li>
					<!--end::Item-->
				</ul>
				<!--end::Breadcrumb-->
			</div>
			<!--end::Page title-->
			<!--begin::Actions-->
			<div class="d-flex align-items-center gap-2 gap-lg-3">

			</div>
			<!--end::Actions-->
		</div>
		<!--end::Toolbar container-->
	</div>
	<!--end::Toolbar-->
	<!--begin::Content-->
	<div id="kt_app_content" class="app-content flex-column-fluid">
		<!--begin::Content container-->
		<div id="kt_app_content_container" class="app-container container-fluid">
			<!--begin::Navbar-->
			<div class="card mb-5 mb-xl-10">
				<div class="card-body pt-9 pb-0">
					<!--begin::Details-->
					<div class="d-flex flex-wrap flex-sm-nowrap">
						<!--begin: Pic-->
						<div class="me-7 mb-4">
							<div class="symbol symbol-100px symbol-lg-160px symbol-fixed position-relative">
								<img src="~/Template/assets/media/avatars/blank.png" alt="image" />
								<div class="position-absolute translate-middle bottom-0 start-100 mb-6 bg-success rounded-circle border border-4 border-body h-20px w-20px"></div>
							</div>
						</div>
						<!--end::Pic-->
						<!--begin::Info-->
						<div class="flex-grow-1">
							<!--begin::Title-->
							<div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
								<!--begin::User-->
								<div class="d-flex flex-column">
									<!--begin::Name-->
									<div class="d-flex align-items-center mb-2">
										<a href="#" class="text-gray-900 text-hover-primary fs-2 fw-bold me-1">@ViewBag.FullName</a>
										<a href="#">
											<i class="ki-duotone ki-verify fs-1 text-primary">
												<span class="path1"></span>
												<span class="path2"></span>
											</i>
										</a>
									</div>
									<!--end::Name-->
									<!--begin::Info-->
									<div class="d-flex flex-wrap fw-semibold fs-6 mb-4 pe-2">
										<a href="#" class="d-flex align-items-center text-gray-500 text-hover-primary me-5 mb-2">
											<i class="ki-duotone ki-profile-circle fs-4 me-1">
												<span class="path1"></span>
												<span class="path2"></span>
												<span class="path3"></span>
											</i>@ViewBag.Roles
										</a>
										<a href="#" class="d-flex align-items-center text-gray-500 text-hover-primary me-5 mb-2">
											<i class="ki-duotone ki-geolocation fs-4 me-1">
												<span class="path1"></span>
												<span class="path2"></span>
											</i>@ViewBag.Location
										</a>
										<a href="#" class="d-flex align-items-center text-gray-500 text-hover-primary mb-2">
											<i class="ki-duotone ki-sms fs-4">
												<span class="path1"></span>
												<span class="path2"></span>
											</i><div id="lbl-email-header">@ViewBag.Email</div>
										</a>
									</div>
									<!--end::Info-->
								</div>
								<!--end::User-->

							</div>
							<!--end::Title-->

						</div>
						<!--end::Info-->
					</div>
					<!--end::Details-->
					<!--begin::Navs-->
					<ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
						<!--begin::Nav item-->
						<li class="nav-item mt-2">
							<a class="nav-link text-active-primary ms-0 me-10 py-5 active" id="overview-tab" data-bs-toggle="tab" href="#overview">Descripción General</a>
						</li>
						<!--end::Nav item-->
						<!--begin::Nav item-->
						<li class="nav-item mt-2">
							<a class="nav-link text-active-primary ms-0 me-10 py-5" id="settings-tab" data-bs-toggle="tab" href="#settings">Ajustes</a>
						</li>
						<!--end::Nav item-->
						<!--begin::Nav item-->
						<li class="nav-item mt-2">
							<a class="nav-link text-active-primary ms-0 me-10 py-5" id="settings-tab" data-bs-toggle="tab" href="#balance">Balance</a>
						</li>
						<!--end::Nav item-->
					</ul>
					<!--begin::Navs-->
				</div>
			</div>
			<!--end::Navbar-->
			

			<div class="tab-content">
				<div class="tab-pane fade show active" id="overview"></div>
				<div class="tab-pane fade" id="settings"></div>
				<div class="tab-pane fade" id="balance"></div>
			</div>
			
			
		</div>
		<!--end::Content container-->
	</div>
	<!--end::Content-->
</div>
<!--end::Content wrapper-->
@section scripts {
	<script>
		$(document).ready(function () {
			LoadOverView();
			LoadSettingsView();
			LoadBalanceView();
		});

		function LoadOverView(){
			$.get('@Url.Action("Overview", "Manage")', function (data) {
				$('#overview').html(data);
			});
		}
		function LoadSettingsView(){
			$.get('@Url.Action("Settings", "Manage")', function (data) {
				$('#settings').html(data);
			});
		}
		function LoadBalanceView(){
			$.get('@Url.Action("Balance", "Manage")', function (data) {
				$('#balance').html(data);
			});
		}
			

		function showModal(urlContent, title, subtitle) {
			fetch(urlContent).then((response) => {
				if (!response.ok) {
					throw new Error(`Error al cargar contenido: ${response.status}`);
				}

				return response.text();
			}).then((data) => {
				$("#contentvModal").html(data);
				$('#title-modal').html(title);
				$('#subtitle-modal').html(subtitle);
				$("#vModal").modal("show");				
			})
			.catch((error) => {
				console.error("Error al cargar el modal:", error);
			});
		}

		function showModalForWithdrawCash(id,accountType) {
			urlContentModal = "@Url.Content("~/Manage/WithdrawCash/?id=")"+ id;
			showModal(urlContentModal, 'Retirar Saldo',accountType);
		}

		function showModalForAddCash(id,accountType) {
			urlContentModal = "@Url.Content("~/Manage/AddCash/?id=")" + id;
			showModal(urlContentModal, 'Agregar Saldo',accountType)
		}
	</script>
}