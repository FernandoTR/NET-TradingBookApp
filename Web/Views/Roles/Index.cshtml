@model List<Web.Models.RolesViewModel>

@{
    ViewBag.Title = "Perfiles";
}
@section Styles {
	<link href="~/Template/assets/plugins/custom/jstree/jstree.bundle.css" rel="stylesheet" type="text/css" />
}
<!--begin::Content wrapper-->
<div class="d-flex flex-column flex-column-fluid">
	<!--begin::Toolbar-->
	<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
		<!--begin::Toolbar container-->
		<div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
			<!--begin::Page title-->
			<div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
				<!--begin::Title-->
				<h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">Perfiles de usuario</h1>
				<!--end::Title-->
				<!--begin::Breadcrumb-->
				<ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">
						<a href="index.html" class="text-muted text-hover-primary">Sistema</a>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item">
						<span class="bullet bg-gray-500 w-5px h-2px"></span>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">Perfiles</li>
					<!--end::Item-->
				</ul>
				<!--end::Breadcrumb-->
			</div>
			<!--end::Page title-->
			<!--begin::Actions-->
			<div class="d-flex align-items-center gap-2 gap-lg-3">			
				<!--begin::Primary button-->
				 <a href="javascript:showModalForNew()" class="btn btn-sm fw-bold btn-primary" data-toggle='tooltip' data-placement='top' title='Agregar un nuevo perfil'>Nuevo</a>
				<!--end::Primary button-->
			</div>
			<!--end::Actions-->
		</div>
		<!--end::Toolbar container-->
	</div>
	<!--end::Toolbar-->
	<!--begin::Content-->
	<div id="kt_app_content" class="app-content flex-column-fluid">
		<!--begin::Content container-->
		<div id="kt_app_content_container" class="app-container container-fluid">
			<!--begin::Card-->
			<div class="card">				
				<!--begin::Card body-->
				<div class="card-body pt-6">
					<!--begin::Table-->
					<table id="dtTable" class="table align-middle table-row-dashed fs-6 gy-5"></table>
					<!--end::Table-->
				</div>
				<!--end::Card body-->
			</div>
			<!--end::Card-->

		</div>
		<!--end::Content container-->
	</div>
	<!--end::Content-->
</div>
<!--end::Content wrapper-->
<!--begin::Modal-->
<div class="modal fade" id="vModal" tabindex="-1" style="display: none;" aria-hidden="true">
			<!--begin::Modal dialog-->
			<div class="modal-dialog modal-dialog-centered mw-650px">
				<!--begin::Modal content-->
				<div class="modal-content rounded">
					<!--begin::Modal header-->
					<div class="modal-header pb-0 border-0 justify-content-end">
						<!--begin::Close-->
						<div class="btn btn-sm btn-icon btn-active-color-primary" data-bs-dismiss="modal">
							<i class="ki-duotone ki-cross fs-1">
								<span class="path1"></span>
								<span class="path2"></span>
							</i>
						</div>
						<!--end::Close-->
					</div>
					<!--begin::Modal header-->
					<!--begin::Modal body-->
					<div class="modal-body scroll-y px-10 px-lg-15 pt-0 pb-15">
						<!--begin:Form-->						
						<!--begin::Heading-->
						<div class="mb-13 text-center">
							<!--begin::Title-->
							<h1 class="mb-3" id="title-modal">Set First Target</h1>
							<!--end::Title-->
							<!--begin::Description-->
							<div class="text-muted fw-semibold fs-5" id="subtitle-modal">If you need more info, please check 
							</div>
							<!--end::Description-->
						</div>
						<!--end::Heading-->
						<!--begin::Input group-->
						<div id="contentvModal"></div>
						
						<!--end:Form-->
					</div>
					<!--end::Modal body-->
				</div>
				<!--end::Modal content-->
			</div>
			<!--end::Modal dialog-->
		</div>
<!--end::Modal-->
@section scripts {	
	<script src="~/Template/assets/plugins/custom/jstree/jstree.bundle.js"></script>
	<script>
		$(document).ready(function () {			

			// Función para cargar datos en la tabla
			function loadTableDate() {
				$('#dtTable').DataTable({
					destroy: true, // Destruir instancia previa para evitar conflictos
					ajax: {
						url: "@Url.Content("~/Roles/JsonDataTable")",
						type: "POST",
						dataType: "json"
					},
					columns: [
						{ name: "rolId", title: "ID", data: "rolId", autoWidth: true,  className: "min-w-80px " },
						{ name: "nameRoles", title: "Nombre", data: "nameRoles", autoWidth: true,  className: "min-w-100px " },
						{ name: "task", title: "Acciones", data: "task", autoWidth: true, orderable: false,  className: "text-end min-w-100px "  }
					],
					processing: true,
					serverSide: true,
					pageLength: 10,
					filter: true,
					language: {
						sProcessing: "Procesando...",
						sLengthMenu: "Mostrar _MENU_ registros",
						sZeroRecords: "No se encontraron resultados",
						sEmptyTable: "Ningún dato disponible en esta tabla",
						sInfo: "Mostrando registros del _START_ al _END_ de un total de _TOTAL_ registros",
						sInfoEmpty: "Mostrando registros del 0 al 0 de un total de 0 registros",
						sInfoFiltered: "(filtrado de un total de _MAX_ registros)",
						sSearch: "Buscar:",
						sLoadingRecords: "Cargando...",
						oPaginate: {
							sFirst: "Primero",
							sLast: "Último",
							sNext: "Siguiente",
							sPrevious: "Anterior"
						},
						buttons: {
							copy: "Copiar",
							colvis: "Visibilidad"
						}
					},
					drawCallback: function () {
						$('[data-toggle="tooltip"]').tooltip();
						KTMenu.createInstances(); // Reinitialize Keenthemes menu
					},
				});
			}

			// Recargar datos de la tabla
			loadTableDate();
		});

		 
        function showModal(urlContent, title, subtitle) {
            fetch(urlContent).then((response) => {
                return response.text();
            }).then((data) => {
                $("#contentvModal").html(data);
                $('#title-modal').html(title);
                $('#subtitle-modal').html(subtitle);
                $("#vModal").modal("show");
                // validateForm();
                $("#NameRoles").focus();
            });
        }

		// configura la llamada al modal con los datos de nuevo
        function showModalForNew() {
            urlContentModal = "@Url.Content("~/Roles/New")";
            showModal(urlContentModal, 'Nuevo Perfil de Usuario','');
            $('[data-toggle="tooltip"]').tooltip()
        }

        // configura la llamada al modal para modificar un perfil
        function showModalForUpdate(id) {
            urlContentModal = "@Url.Content("~/Roles/Edit/?id=")" + id;
            showModal(urlContentModal, 'Editar Perfil de Usuario','')
        }
	</script>


}