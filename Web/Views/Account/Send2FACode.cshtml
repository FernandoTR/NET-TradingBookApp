@model Web.Models.Send2FACodeViewModel
@{
	ViewBag.Title = "Verificación de Dos Factores";
}
<!--begin::Root-->
<div class="d-flex flex-column flex-root" id="kt_app_root">
	<!--begin::Authentication - Two-factor -->
	<div class="d-flex flex-column flex-lg-row flex-column-fluid">
		<!--begin::Body-->
		<div class="d-flex flex-column flex-lg-row-fluid w-lg-50 p-10 order-2 order-lg-1">
			<!--begin::Form-->
			<div class="d-flex flex-center flex-column flex-lg-row-fluid">
				<!--begin::Wrapper-->
				<div class="w-lg-500px p-10">
					<!--begin::Form-->
					@using (Html.BeginForm("Verify2FACode", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post, true, new { @class = "form-horizontal", role = "form", id = "myForm" }))
					{
						@Html.AntiForgeryToken()
						@Html.Hidden("Code", @Model.Code)
						@Html.Hidden("Provider", @Model.Provider)
						@Html.Hidden("ReturnUrl", @Model.ReturnUrl)
						@Html.Hidden("RememberMe", @Model.RememberMe)
						@Html.Hidden("UserId", @Model.UserId)			

						<!--begin::Icon-->
						<div class="text-center mb-10">
							<img alt="Logo" class="mh-125px" src="~/Template/assets/media/svg/misc/smartphone-2.svg" />
						</div>
						<!--end::Icon-->
						<!--begin::Heading-->
						<div class="text-center mb-10">
							<!--begin::Title-->
							<h1 class="text-gray-900 mb-3">Verificación de Dos Factores</h1>
							<!--end::Title-->
							<!--begin::Sub-title-->
							<div class="text-muted fw-semibold fs-5 mb-5">@(Model.Provider != "Authenticator" ? "Ingresa el código de verificación que acabamos de enviar a" : "Revise su aplicación preferida para códigos de un solo uso y copie el código")</div>
							<!--end::Sub-title-->
							<!--begin::Mobile no-->
							<div class="fw-bold text-gray-900 fs-3">@(Model.Provider != "Authenticator" ? Model.SendTo : "")</div>
							<!--end::Mobile no-->
						</div>
						<!--end::Heading-->
						<!--begin::Section-->
						<div class="mb-10">
							<!--begin::Label-->
							<div class="fw-bold text-start text-gray-900 fs-6 mb-1 ms-1">Escribe tu código de seguridad de 6 dígitos</div>
							<!--end::Label-->
							<!--begin::Input group-->
							<div class="d-flex flex-wrap flex-stack" id="input-container">
								<input type="text" name="code_1" data-inputmask="'mask': '9', 'placeholder': ''" maxlength="1" class="form-control bg-transparent h-60px w-60px fs-2qx text-center mx-1 my-2" value="" autocomplete="off" />
								<input type="text" name="code_2" data-inputmask="'mask': '9', 'placeholder': ''" maxlength="1" class="form-control bg-transparent h-60px w-60px fs-2qx text-center mx-1 my-2" value="" autocomplete="off" />
								<input type="text" name="code_3" data-inputmask="'mask': '9', 'placeholder': ''" maxlength="1" class="form-control bg-transparent h-60px w-60px fs-2qx text-center mx-1 my-2" value="" autocomplete="off" />
								<input type="text" name="code_4" data-inputmask="'mask': '9', 'placeholder': ''" maxlength="1" class="form-control bg-transparent h-60px w-60px fs-2qx text-center mx-1 my-2" value="" autocomplete="off" />
								<input type="text" name="code_5" data-inputmask="'mask': '9', 'placeholder': ''" maxlength="1" class="form-control bg-transparent h-60px w-60px fs-2qx text-center mx-1 my-2" value="" autocomplete="off" />
								<input type="text" name="code_6" data-inputmask="'mask': '9', 'placeholder': ''" maxlength="1" class="form-control bg-transparent h-60px w-60px fs-2qx text-center mx-1 my-2" value="" autocomplete="off" />
							</div>
							<!--begin::Input group-->
						</div>
						<!--end::Section-->
						<!--begin::Submit-->
						<div class="d-flex flex-center">
							<button type="button" id="kt_sing_in_two_factor_submit" class="btn btn-lg btn-primary fw-bold" style="background-color: #FCD535!important; color: black!important;">
								<span class="indicator-label">Enviar</span>
								<span class="indicator-progress">
									Espere por favor...
									<span class="spinner-border spinner-border-sm align-middle ms-2"></span>
								</span>
							</button>
						</div>
						<!--end::Submit-->
					}
					<!--end::Form-->
					<!--begin::Notice-->
					<div class="text-center fw-semibold fs-5 mt-10">
						@* @Html.ActionLink("Probar otro método","SendCode","Account",
															TempData["Send2FACodeData"].ToString(),
											new { @class = "link-primary fs-5 me-1" }
										) *@
						<a href="javascript:setTempData()" class="link-primary fs-5 me-1">Probar otro método</a> 
					</div>
					<!--end::Notice-->
				</div>
				<!--end::Wrapper-->
			</div>
			<!--end::Form-->
			<!--begin::Footer-->
			<div class="w-lg-500px d-flex flex-stack px-10 mx-auto"></div>
			<!--end::Footer-->
		</div>
		<!--end::Body-->
		<!--begin::Aside-->		
		<!--end::Aside-->
	</div>
	<!--end::Authentication - Two-factor-->
</div>
<!--end::Root-->
@section scripts {
	<script>
		$(document).ready(function() {
			const inputs = document.querySelectorAll("#input-container input");

			inputs.forEach((input, index) => {
			  input.addEventListener("input", function () {
				if (input.value.length === input.maxLength) {
				  // Mueve el foco al siguiente input si existe
				  const nextInput = inputs[index + 1];
				  if (nextInput) {
					nextInput.focus();
				  }
				}
			  });

			  // Permitir retroceso al input anterior
			  input.addEventListener("keydown", function (e) {
				if (e.key === "Backspace" && input.value === "") {
				  const prevInput = inputs[index - 1];
				  if (prevInput) {
					prevInput.focus();
				  }
				}
			  });
			});

			


		});

		// Define form element
		const form = document.getElementById('myForm');

		function validateInputs() {
			// Recupera todos los inputs cuyo nombre empiece con "code_"
			const inputs = document.querySelectorAll('input[name^="code_"]');

			// Concatena los valores de los inputs
			const code = Array.from(inputs).map(input => input.value).join('');
			
			// Retorna true si la longitud del código es exactamente 6
			document.getElementById('Code').value = code;
			return code.length === 6;
		}


		// Submit button handler
		const submitButton = document.getElementById('kt_sing_in_two_factor_submit');
		submitButton.addEventListener('click', function (e) {
			// Prevent default button action
			e.preventDefault();

			// Validate form 
			if (!validateInputs())
			{
				ShowNotification(4,"Ingrese un código de seguridad válido e inténtelo nuevamente.")
				return;
			}

			// Show loading indication
			submitButton.setAttribute('data-kt-indicator', 'on');

			// Disable button to avoid multiple click
			submitButton.disabled = true;

			form.submit(); 
		});

		function setTempData() {
			const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

			// Crear los datos a enviar
			const model = {
				Provider: document.querySelector('#Provider')?.value || "",
				Code: "",
				ReturnUrl: document.querySelector('#ReturnUrl')?.value || "",
				RememberBrowser: document.querySelector('#RememberBrowser')?.value === "true",
				RememberMe: document.querySelector('#RememberMe')?.value === "true",
				UserId: document.querySelector('#UserId')?.value || "",
				SendTo: ""
			};

			const url = "@Url.Content("~/Account/SetTempData")";
			fetch(url, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'RequestVerificationToken': token
				},
				body: JSON.stringify(model)
			})
			.then(response => response.json())
			.then(data => {
				if (data.success) {
					window.location.href = data.redirectUrl;
				} else {
					console.error('Error al procesar la solicitud');
				}
			})
			.catch(error => console.error('Error:', error));
			
		}
	</script>
}