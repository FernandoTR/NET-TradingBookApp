@{
	ViewBag.Title = "Solicitud enviada";
}

<!--begin::Root-->
<div class="d-flex flex-column flex-root" id="kt_app_root">
	<!--begin::Page bg image-->
	<style>
		body {
			background-image: url('../Template/assets/media/auth/bg1.jpg');
		}

		[data-bs-theme="dark"] body {
			background-image: url('../Template/assets/media/auth/bg1-dark.jpg');
		}</style>
	<!--end::Page bg image-->
	<!--begin::Authentication - Signup Welcome Message -->
	<div class="d-flex flex-column flex-center flex-column-fluid">
		<!--begin::Content-->
		<div class="d-flex flex-column flex-center text-center p-10">
			<!--begin::Wrapper-->
			<div class="card card-flush w-lg-650px py-5">
				<div class="card-body py-15 py-lg-20">
					<!--begin::Logo-->
					<div class="mb-14">
						<a href="index.html" class="">
							<img alt="Logo" src="~/Template/assets/media/logos/custom-2.svg" class="h-40px" />
						</a>
					</div>
					<!--end::Logo-->
					<!--begin::Title-->
					<h1 class="fw-bolder text-gray-900 mb-5">Solicitud de recuperación de acceso recibida.</h1>
					<!--end::Title-->
					<!--begin::Message-->
					<div class="fs-6 fw-semibold text-gray-500 mb-10">
						Si en nuestro registro se encuentra el correo electróico que indicaste y es una cuenta activa, en breve recibirás en tu buzón un mensaje con las indicaciones necesarias para recuperar tu acceso.
						<br />
						<br />

						Si no recibes el correo con instrucciones, escribe a: <a href='mailto:@ViewBag.emailSupport' class="link-primary fw-semibold"> @ViewBag.emailSupport </a> 						
						<br />indica el correo electrónico que fue registrado y tu número de empleado.
					</div>
					<!--end::Message-->
					<!--begin::Link-->
					<div class="mb-11">
						<a href="@Url.Action("SignIn","Account")" class="btn btn-sm btn-primary">Iniciar sesión</a>
					</div>
					<!--end::Link-->
					<!--begin::Illustration-->
					<div class="mb-0">
						<img src="~/Template/assets/media/auth/ok.png" class="mw-100 mh-300px theme-light-show" alt="" />
						<img src="~/Template/assets/media/auth/ok-dark.png" class="mw-100 mh-300px theme-dark-show" alt="" />
					</div>
					<!--end::Illustration-->
				</div>
			</div>
			<!--end::Wrapper-->
		</div>
		<!--end::Content-->
	</div>
	<!--end::Authentication - Signup Welcome Message-->
</div>
<!--end::Root-->