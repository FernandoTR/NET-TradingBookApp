@model List<Web.Models.CatFrameViewModel>

@{
	ViewData["Title"] = "Frame";
}

<!--begin::Content wrapper-->
<div class="d-flex flex-column flex-column-fluid">
	<!--begin::Toolbar-->
	<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
		<!--begin::Toolbar container-->
		<div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
			<!--begin::Page title-->
			<div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
				<!--begin::Title-->
				<h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">Catálogo de Frames</h1>
				<!--end::Title-->
				<!--begin::Breadcrumb-->
				<ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">
						<a href="index.html" class="text-muted text-hover-primary">Configuración</a>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item">
						<span class="bullet bg-gray-500 w-5px h-2px"></span>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">
						<a href="index.html" class="text-muted text-hover-primary">Catálogos</a>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item">
						<span class="bullet bg-gray-500 w-5px h-2px"></span>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">Frames</li>
					<!--end::Item-->
				</ul>
				<!--end::Breadcrumb-->
			</div>
			<!--end::Page title-->
			<!--begin::Actions-->
			<div class="d-flex align-items-center gap-2 gap-lg-3">
				<!--begin::Primary button-->
				<a href="javascript:showModalForNew()" class="btn btn-sm fw-bold btn-primary" data-toggle='tooltip' data-placement='top' title='Agregar nuevo frame'>Nuevo</a>
				<!--end::Primary button-->
			</div>
			<!--end::Actions-->
		</div>
		<!--end::Toolbar container-->
	</div>
	<!--end::Toolbar-->
	<!--begin::Content-->
	<div id="kt_app_content" class="app-content flex-column-fluid">
		<!--begin::Content container-->
		<div id="kt_app_content_container" class="app-container container-fluid">
			<!--begin::Card-->
			<div class="card">
				<!--begin::Card body-->
				<div class="card-body pt-6">
					<!--begin::Table-->
					<table id="dtTable" class="table align-middle table-row-dashed fs-6 gy-5"></table>
					<!--end::Table-->
				</div>
				<!--end::Card body-->
			</div>
			<!--end::Card-->

		</div>
		<!--end::Content container-->
	</div>
	<!--end::Content-->
</div>
<!--end::Content wrapper-->
@section scripts {
	<script>
		$(document).ready(function () {


			// Función para cargar datos en la tabla
			function loadTableDate() {
				$('#dtTable').DataTable({
					destroy: true, // Destruir instancia previa para evitar conflictos
					ajax: {
						url: "@Url.Content("~/CatFrame/JsonDataTable")",
						type: "POST",
						dataType: "json"
					},
					columns: [
						{ name: "id", title: "Número", data: "id", autoWidth: true,  className: "min-w-50px " },
						{ name: "code", title: "Código", data: "code", autoWidth: true,  className: "min-w-100px " },
						{ name: "description", title: "Descripción", data: "description", autoWidth: true,  className: "text-center min-w-200px " },
						{ name: "task", title: "Acciones", data: "task", autoWidth: true, orderable: false,  className: "text-end min-w-100px "  }
					],
					processing: true,
					serverSide: true,
					pageLength: 10,
					filter: true,
					language: {
						sProcessing: "Procesando...",
						sLengthMenu: "Mostrar _MENU_ registros",
						sZeroRecords: "No se encontraron resultados",
						sEmptyTable: "Ningún dato disponible en esta tabla",
						sInfo: "Mostrando registros del _START_ al _END_ de un total de _TOTAL_ registros",
						sInfoEmpty: "Mostrando registros del 0 al 0 de un total de 0 registros",
						sInfoFiltered: "(filtrado de un total de _MAX_ registros)",
						sSearch: "Buscar:",
						sLoadingRecords: "Cargando...",
						oPaginate: {
							sFirst: "Primero",
							sLast: "Último",
							sNext: "Siguiente",
							sPrevious: "Anterior"
						},
						oAria: {
							sSortAscending: ": Activar para ordenar la columna de manera ascendente",
							sSortDescending: ": Activar para ordenar la columna de manera descendente"
						},
						buttons: {
							copy: "Copiar",
							colvis: "Visibilidad"
						}
					},
					drawCallback: function () {
						$('[data-toggle="tooltip"]').tooltip();
						KTMenu.createInstances(); // Reinitialize Keenthemes menu
					},
				});
			}

			// Recargar datos de la tabla
			loadTableDate();
		});


		function showModal(urlContent, title, subtitle) {
			fetch(urlContent).then((response) => {
				return response.text();
			}).then((data) => {
				$("#contentvModal").html(data);
				$('#title-modal').html(title);
				$('#subtitle-modal').html(subtitle);
				$("#vModal").modal("show");
			});
		}


		function showModalForNew() {
			urlContentModal = "@Url.Content("~/CatFrame/New")";
			showModal(urlContentModal, 'Nuevo Frame','');
			$('[data-toggle="tooltip"]').tooltip()
		}


		function showModalForUpdate(id) {
			urlContentModal = "@Url.Content("~/CatFrame/Edit/?id=")" + id;
			showModal(urlContentModal, 'Editar Frame','')
		}

		function showModaltoDelete(id) {
			console.log(id)
			$("#confirmButtonYes").bind('click', () => {
				$("#confirmButtonYes").unbind('click');
				$("#confirmDialog").modal("hide");
				processingDelete(id);
			});
			$('#confirmDialogContent').html('¿Esta usted seguro de eliminar el frame?')
			$('#confirmTitle').html('Dar de baja el frame');
			$("#confirmDialog").modal("show");
		}

		function processingDelete(id) {
			var urlConfirmModal = "@Url.Content("~/CatFrame/Delete")";
			fetch(urlConfirmModal, {
				method: 'POST',
				body: JSON.stringify(id),
				headers: {
					'Content-Type': 'application/json'
				}
			}).then(res => res.text())
				.catch(error => console.error('Error:', error))
				.then((data) => {
					if (data === 'true') {
						var urlIndex = "@Html.Raw(Url.Action("Index", "CatFrame", new { message = "El frame fue eliminado correctamente.", notification = "Success" }))";
					} else {
						var urlIndex = "@Html.Raw(Url.Action("Index", "CatFrame", new { message = "Ocurrio un problema", notification = Web.Models.Enums.NotificationType.Error }))";
					}
					window.location.href = urlIndex;
				});
		}

	</script>
}