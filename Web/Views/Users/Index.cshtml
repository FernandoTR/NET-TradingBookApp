@model List<Web.Models.UsersListViewModel>

@{
    ViewBag.Title = "Usuarios";

}

<!--begin::Content wrapper-->
<div class="d-flex flex-column flex-column-fluid">
	<!--begin::Toolbar-->
	<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
		<!--begin::Toolbar container-->
		<div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
			<!--begin::Page title-->
			<div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
				<!--begin::Title-->
				<h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">Catálogo de Usuarios</h1>
				<!--end::Title-->
				<!--begin::Breadcrumb-->
				<ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">
						<a href="index.html" class="text-muted text-hover-primary">Sistema</a>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item">
						<span class="bullet bg-gray-500 w-5px h-2px"></span>
					</li>
					<!--end::Item-->
					<!--begin::Item-->
					<li class="breadcrumb-item text-muted">Usuarios</li>
					<!--end::Item-->
				</ul>
				<!--end::Breadcrumb-->
			</div>
			<!--end::Page title-->
			<!--begin::Actions-->
			<div class="d-flex align-items-center gap-2 gap-lg-3">
				
			</div>
			<!--end::Actions-->
		</div>
		<!--end::Toolbar container-->
	</div>
	<!--end::Toolbar-->
	<!--begin::Content-->
	<div id="kt_app_content" class="app-content flex-column-fluid">
		<!--begin::Content container-->
		<div id="kt_app_content_container" class="app-container container-fluid">
			<!--begin::Card-->
			<div class="card">
				<!--begin::Card body-->
				<div class="card-body pt-6">
					<!--begin::Table-->
					<table id="dtTable" class="table align-middle table-row-dashed fs-6 gy-5"></table>
					<!--end::Table-->
				</div>
				<!--end::Card body-->
			</div>
			<!--end::Card-->

		</div>
		<!--end::Content container-->
	</div>
	<!--end::Content-->
</div>
<!--end::Content wrapper-->

<!--begin::Modal-->
<div class="modal fade" id="vModal" tabindex="-1" style="display: none;" aria-hidden="true">
	<!--begin::Modal dialog-->
	<div class="modal-dialog modal-dialog-centered mw-650px">
		<!--begin::Modal content-->
		<div class="modal-content rounded">
			<!--begin::Modal header-->
			<div class="modal-header pb-0 border-0 justify-content-end">
				<!--begin::Close-->
				<div class="btn btn-sm btn-icon btn-active-color-primary" data-bs-dismiss="modal">
					<i class="ki-duotone ki-cross fs-1">
						<span class="path1"></span>
						<span class="path2"></span>
					</i>
				</div>
				<!--end::Close-->
			</div>
			<!--begin::Modal header-->
			<!--begin::Modal body-->
			<div class="modal-body scroll-y px-10 px-lg-15 pt-0 pb-15">
				<!--begin:Form-->
				<!--begin::Heading-->
				<div class="mb-13 text-center">
					<!--begin::Title-->
					<h1 class="mb-3" id="title-modal">Set First Target</h1>
					<!--end::Title-->
					<!--begin::Description-->
					<div class="text-muted fw-semibold fs-5" id="subtitle-modal">
						If you need more info, please check
					</div>
					<!--end::Description-->
				</div>
				<!--end::Heading-->
				<!--begin::Input group-->
				<div id="contentvModal"></div>

				<!--end:Form-->
			</div>
			<!--end::Modal body-->
		</div>
		<!--end::Modal content-->
	</div>
	<!--end::Modal dialog-->
</div>
<!--end::Modal-->
<!--begin::Modal-Confirmacion-->
<div class="modal fade" tabindex="-1" id="confirmDialog">
	<div class="modal-dialog">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="confirmTitle"></h5>

				<!--begin::Close-->
				<div class="btn btn-sm btn-icon btn-active-color-primary" data-bs-dismiss="modal">
					<i class="ki-duotone ki-cross fs-1">
						<span class="path1"></span>
						<span class="path2"></span>
					</i>
				</div>
				<!--end::Close-->
			</div>

			<div class="modal-body">
				<p id="confirmDialogContent"></p>
			</div>

			<div class="modal-footer">
				<button type="button" class="btn btn-primary" id="confirmButtonYes">Si</button>
				<button type="button" class="btn btn-light" data-bs-dismiss="modal">No</button>

			</div>
		</div>
	</div>
</div>
<!--end::Modal-Confirmacion-->
@section scripts {
	<script>
		$(document).ready(function () {

			// Función para cargar datos en la tabla
			function loadTableDate() {
				$('#dtTable').DataTable({
					destroy: true, // Destruir instancia previa para evitar conflictos
					ajax: {
						url: "@Url.Content("~/Users/JsonDataTable")",
						type: "POST",
						dataType: "json"
					},
					columns: [
						{ name: "email", title: "Usuario", data: "email", autoWidth: true,  className: "min-w-100px " },
						{ name: "emailConfirmed", title: "Correo Confirmado", data: "emailConfirmed", autoWidth: true,  className: "text-center min-w-100px ", render: renderTrueFalse },
						{ name: "resetFlag", title: "Bandera Reseteo", data: "resetFlag", autoWidth: true,  className: "text-center min-w-100px ", render: renderFlag },
						{ name: "name", title: "Rol", data: "name", autoWidth: true,  className: "text-center min-w-100px " },
						{ name: "status", title: "Estatus", data: "status", autoWidth: true,  className: "text-center min-w-100px ", render: renderStatusEmployee },
						{ name: "accesFailedCount", title: "Accesos Erroneos", data: "accesFailedCount", autoWidth: true,  className: "text-center min-w-100px " },
						{ name: "passwordEndDate",
						  title: "Fecha Fin Contraseña",
						  data: "passwordEndDate",
						  autoWidth: true,
						  className: "text-center min-w-100px ",
						  render: function (data, type, row) {
								// Formatear la fecha solo en las celdas visibles
								return type === 'display' || type === 'filter'
									? moment(data).format("DD/MM/YYYY HH:mm:ss")
									: data;
							}
						},
						{ name: "task", title: "Acciones", data: "task", autoWidth: true, orderable: false,  className: "text-end min-w-100px "  }
					],
					processing: true,
					serverSide: true,
					pageLength: 10,
					filter: true,
					language: {
						sProcessing: "Procesando...",
						sLengthMenu: "Mostrar _MENU_ registros",
						sZeroRecords: "No se encontraron resultados",
						sEmptyTable: "Ningún dato disponible en esta tabla",
						sInfo: "Mostrando registros del _START_ al _END_ de un total de _TOTAL_ registros",
						sInfoEmpty: "Mostrando registros del 0 al 0 de un total de 0 registros",
						sInfoFiltered: "(filtrado de un total de _MAX_ registros)",
						sSearch: "Buscar:",
						sLoadingRecords: "Cargando...",
						oPaginate: {
							sFirst: "Primero",
							sLast: "Último",
							sNext: "Siguiente",
							sPrevious: "Anterior"
						},
						oAria: {
							sSortAscending: ": Activar para ordenar la columna de manera ascendente",
							sSortDescending: ": Activar para ordenar la columna de manera descendente"
						},
						buttons: {
							copy: "Copiar",
							colvis: "Visibilidad"
						}
					},
					drawCallback: function () {
						$('[data-toggle="tooltip"]').tooltip();
						KTMenu.createInstances(); // Reinitialize Keenthemes menu
					},					
				});
			}

			// Recargar datos de la tabla
			loadTableDate();			
		});

		function showModal(urlContent, title, subtitle) {
			fetch(urlContent).then((response) => {
				return response.text();
			}).then((data) => {
				$("#contentvModal").html(data);
				$('#title-modal').html(title);
				$('#subtitle-modal').html(subtitle);
				$("#vModal").modal("show");
				$("#EmployeeNumber").focus();
			});
		}

		//funcion para editar usuario
		function showModalForUpdate(id) {
			urlContentModal = "@Url.Content("~/Users/Edit/?id=")" + id;
			showModal(urlContentModal, 'Editar Usuario','')
		}

		//funcion para editar o asignar roles al usuario
		function showModalForModifyRoles(id) {		
			urlContentModal = "@Url.Content("~/Users/Edit/?id=")" + id;
			showModal(urlContentModal, 'Modificar Perfil Para el Usuario','')
		}

		//funcion para dar de baja logica a un Usuario el proceso es por ID
		function toDeleteUser(id) {		   
			$("#confirmButtonYes").bind('click', () => {
				$("#confirmButtonYes").unbind('click');
				$("#confirmDialog").modal("hide");
				processingDelete(id);
			});
			$('#confirmDialogContent').html('¿Esta usted seguro de eliminar/activar Usuario?')
			$('#confirmTitle').html('Cambiar estatus del usuario');
			$("#confirmDialog").modal("show");
		}

		function processingDelete(id) {	
			console.log("id eliminar" + id);
			var urlConfirmModal = "@Url.Content("~/Users/Delete")";
			fetch(urlConfirmModal, {
				method: 'POST',
				body: JSON.stringify(id), // data can be `string` or {object}!
				headers: {
					'Content-Type': 'application/json'
				}
			}).then(res => res.text())
				.catch(error => console.error('Error:', error))
				.then((data) => {
					if (data === 'true') {
						var urlIndex = "@Html.Raw(Url.Action("Index", "Users", new { message = "Se actualizo el estatus del usuario", notification = "Success" }))";
					} else {
						var urlIndex = "@Html.Raw(Url.Action("Index", "Users", new { message = "Ocurrio un problema", notification = Web.Models.Enums.NotificationType.Error }))";
					}
				   
					window.location.href = urlIndex;
				});
		}

	</script>


}