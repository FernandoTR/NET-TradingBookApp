<script>
	$(document).ready(function () {
		// Define form element
		let form = document.getElementById('frmdata');

		 // Init form validation rules.
		var validator = FormValidation.formValidation(
			form,
			{
				fields: {
					'CategoryId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'AccountTypeId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'InstrumentId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'DayId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'StageId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'FigureId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'FrameId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'TriggerId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'DirectionId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
					'SceneryId': {
						validators: {
							notEmpty: {
								message: 'Obligatorio'
							},
						}
					},
				},
				plugins: {
					trigger: new FormValidation.plugins.Trigger(),
					bootstrap: new FormValidation.plugins.Bootstrap5({
						rowSelector: '.fv-row',
						eleInvalidClass: '',
						eleValidClass: ''
					}),
				}

			}
		);
	
		const submitButton = document.getElementById('btnSave');
		submitButton.addEventListener('click', function (e) {
			// Prevent default button action
			e.preventDefault();

			// Validate form before submit
			if (validator) {
				validator.validate().then(function (status) {
					if (status == 'Valid') {
						// Show loading indication
						submitButton.setAttribute('data-kt-indicator', 'on');

						// Disable button to avoid multiple click
						submitButton.disabled = true;

						form.submit(); // Submit form
					}
				});
			}

		});
	});

	//Script para que funcione el select2 en el modal
	$('#CategoryId, #AccountTypeId, #InstrumentId, #DayId, #DayId, #StageId, #FigureId, #FrameId, #TriggerId, #DirectionId, #SceneryId, #OrderTypeId, #TradeTypeId, #LocationType, #IsTrendAligned, #IsPivotZone, #ConfirmationType')
	.select2({ dropdownParent: $('#vModal'), minimumResultsForSearch: Infinity });

	$("#Time").flatpickr({
		enableTime: true,
		noCalendar: true,
		dateFormat: "H:i", // Formato hora:minutos
		minuteIncrement: 1, // <-- Esto hace que avance de 1 en 1 minuto
		allowInput: true    // Permite escribir manualmente la hora
	});

	$("#CreationDate").flatpickr({
	enableTime: false,
	noCalendar: false,
	locale: "es",
	allowInput: true,    // Permite escribir manualmente la fecha
	onChange: function(selectedDates, dateStr, instance) {
		if (selectedDates.length > 0) {
		// Obtén la fecha seleccionada como objeto Date
		const selectedDate = selectedDates[0];

		// Obtén el número del día de la semana (0 = domingo, 6 = sábado)
		const dayOfWeek = selectedDate.getDay();

		// Establece el valor del día de la semana en el select
		$('#DayId').val(dayOfWeek == 0 ? 7 : dayOfWeek).trigger('change');
		}
		}
	});
		
</script>