@model Web.Models.OrdersViewModel

@{
    Layout = null;

    var CategoryItems = (List<SelectListItem>)ViewBag.CategoryItems;
    var AccountTypeItems = (List<SelectListItem>)ViewBag.AccountTypeItems;
    var InstrumentItems = (List<SelectListItem>)ViewBag.InstrumentItems;
    var DayItems = (List<SelectListItem>)ViewBag.DayItems;
    var StageItems = (List<SelectListItem>)ViewBag.StageItems;
    var FigureItems = (List<SelectListItem>)ViewBag.FigureItems;
    var FrameItems = (List<SelectListItem>)ViewBag.FrameItems;
    var TriggerItems = (List<SelectListItem>)ViewBag.TriggerItems;
    var DirectionItems = (List<SelectListItem>)ViewBag.DirectionItems;
    var SceneryItems = (List<SelectListItem>)ViewBag.SceneryItems;
